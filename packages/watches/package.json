{
  "name": "@personal-ai/watches",
  "version": "0.1.0",
  "description": "Watch aliases for Programs: user-facing watch vocabulary over plugin-schedules",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
